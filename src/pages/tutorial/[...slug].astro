---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const lessons = await getCollection('tutorial');
  return lessons.map(lesson => ({
    params: { slug: lesson.id },
    props: { lesson, allLessons: lessons },
  }));
}

const { lesson, allLessons } = Astro.props;
const { Content } = await render(lesson);

// Get all lessons in the current module for the sidebar
const moduleLessons = allLessons
  .filter(l => l.data.module === lesson.data.module)
  .sort((a, b) => a.data.order - b.data.order);

const currentIndex = moduleLessons.findIndex(l => l.id === lesson.id);
const prevLesson = currentIndex > 0 ? moduleLessons[currentIndex - 1] : null;
const nextLesson = currentIndex < moduleLessons.length - 1 ? moduleLessons[currentIndex + 1] : null;

const frontmatter = {
  title: `${lesson.data.title} - Modul ${lesson.data.moduleTitle}`,
  description: lesson.data.description,
};
---

<Layout frontmatter={frontmatter}>
  <div class="min-h-screen bg-slate-950 text-slate-300 flex flex-col md:flex-row">
    
    <!-- Mobile Header (Visible only on small screens) -->
    <div class="md:hidden sticky top-0 z-40 bg-slate-900 border-b border-white/10 p-4 flex items-center justify-between">
      <a href="/tutorial" class="text-sm font-semibold flex items-center gap-2">
        <span class="text-xl">←</span> Roadmap
      </a>
      <div class="text-sm font-semibold truncate px-4">{lesson.data.moduleTitle}</div>
    </div>

    <!-- Sidebar -->
    <aside class="hidden md:flex flex-col w-72 h-screen sticky top-0 bg-slate-900/50 border-r border-white/10 flex-shrink-0">
      <!-- Sidebar Header -->
      <div class="p-6 border-b border-white/5">
        <a href="/tutorial" class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-white transition-colors mb-6">
          <span>←</span> Kembali ke Roadmap
        </a>
        <div class="flex items-center gap-3">
          <div class={`w-10 h-10 rounded-xl bg-gradient-to-br ${lesson.data.moduleColor} flex items-center justify-center text-xl shadow-lg`}>
            {lesson.data.moduleEmoji}
          </div>
          <div>
            <div class="text-xs text-slate-500 uppercase tracking-widest font-bold mb-0.5">Modul {lesson.data.module.replace('modul-', '')}</div>
            <div class="font-bold text-white text-sm leading-tight">{lesson.data.moduleTitle}</div>
          </div>
        </div>
      </div>

      <!-- Sidebar Links -->
      <div class="flex-1 overflow-y-auto p-4 space-y-1">
        {moduleLessons.map(l => {
          const isActive = l.id === lesson.id;
          return (
            <a 
              href={`/tutorial/${l.id}`}
              class={`flex items-start gap-3 p-3 rounded-xl transition-all text-sm ${isActive ? 'bg-white/10 text-white font-medium shadow-sm' : 'text-slate-400 hover:text-slate-200 hover:bg-white/5'}`}
            >
              <span class="text-lg leading-none">{l.data.icon}</span>
              <span class="leading-snug pt-0.5">{l.data.title}</span>
            </a>
          );
        })}
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 overflow-x-hidden">
      <div class="max-w-3xl mx-auto px-6 py-12 md:py-16">
        
        <!-- Breadcrumb -->
        <div class="flex items-center gap-2 text-sm font-medium text-slate-500 mb-8">
          <span>Modul {lesson.data.module.replace('modul-', '')}</span>
          <span>/</span>
          <span class={lesson.data.moduleAccentColor}>{lesson.data.title}</span>
        </div>

        <!-- Article Header -->
        <header class="mb-12">
          <div class="text-5xl mb-6">{lesson.data.icon}</div>
          <h1 class="text-3xl md:text-5xl font-black text-white mb-4 leading-tight">{lesson.data.title}</h1>
          <p class="text-lg text-slate-400">{lesson.data.description}</p>
        </header>

        <!-- Markdown Content -->
        <article class="prose prose-invert prose-slate max-w-none 
          prose-headings:font-bold prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-6 prose-h2:pb-2 prose-h2:border-b prose-h2:border-white/10
          prose-p:text-slate-300 prose-p:leading-relaxed
          prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline
          prose-strong:text-white prose-strong:font-semibold
          prose-ul:text-slate-300 prose-li:my-1
          prose-code:text-pink-400 prose-code:bg-pink-400/10 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:before:content-none prose-code:after:content-none
          prose-pre:bg-slate-900 prose-pre:border prose-pre:border-white/10 prose-pre:shadow-xl prose-pre:rounded-xl
          prose-th:text-white prose-th:bg-white/5 prose-td:border-white/10 prose-th:border-white/10">
          <Content />
        </article>

        <!-- Navigation Buttons -->
        <div class="mt-20 pt-8 border-t border-white/10 flex flex-col sm:flex-row gap-4 justify-between">
          {prevLesson ? (
            <a href={`/tutorial/${prevLesson.id}`} class="flex-1 group flex flex-col bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl p-4 transition-colors">
              <span class="text-xs text-slate-500 mb-1 uppercase tracking-wider font-semibold group-hover:text-slate-400">← Sebelumnya</span>
              <span class="font-medium text-white truncate">{prevLesson.data.title}</span>
            </a>
          ) : (
            <div class="flex-1"></div>
          )}
          
          {nextLesson ? (
            <a href={`/tutorial/${nextLesson.id}`} class="flex-1 group flex flex-col items-end text-right bg-white/5 hover:bg-white/10 border border-white/10 rounded-2xl p-4 transition-colors">
              <span class="text-xs text-slate-500 mb-1 uppercase tracking-wider font-semibold group-hover:text-slate-400">Berikutnya →</span>
              <span class="font-medium text-white truncate">{nextLesson.data.title}</span>
            </a>
          ) : (
            <a href="/tutorial" class={`flex-1 group flex flex-col items-center justify-center text-center bg-gradient-to-r ${lesson.data.moduleColor} rounded-2xl p-4 transition-transform hover:scale-[1.02] shadow-lg`}>
              <span class="font-bold text-white">Selesai! Kembali ke Roadmap 🚀</span>
            </a>
          )}
        </div>

      </div>
    </main>

  </div>
</Layout>
