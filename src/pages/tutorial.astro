---
import Layout from '../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const allLessons = await getCollection('tutorial');

type ModuleGroup = {
  id: string;
  title: string;
  emoji: string;
  color: string;
  borderColor: string;
  accentColor: string;
  bgAccent?: string;
  lessons: CollectionEntry<'tutorial'>[];
};

// Mengelompokkan materi berdasarkan modul
const modules = allLessons.reduce((acc, lesson: CollectionEntry<'tutorial'>) => {
  const modId = lesson.data.module;
  if (!acc[modId]) {
    acc[modId] = {
      id: modId,
      title: lesson.data.moduleTitle,
      emoji: lesson.data.moduleEmoji,
      color: lesson.data.moduleColor,
      borderColor: lesson.data.moduleBorderColor,
      accentColor: lesson.data.moduleAccentColor,
      lessons: []
    };
  }
  acc[modId].lessons.push(lesson);
  return acc;
}, {} as Record<string, ModuleGroup>);

// Konversi ke array dan urutkan
const sortedModules = Object.values(modules).sort((a, b) => a.id.localeCompare(b.id));

// Urutkan pelajaran di setiap modul
sortedModules.forEach(mod => {
  mod.lessons.sort((a, b) => a.data.order - b.data.order);
});

const frontmatter = {
  title: 'Roadmap Fullstack Web Developer',
  description: 'Daftar modul dan pelajaran untuk kelas Fullstack.',
};
---

<Layout frontmatter={frontmatter}>
  <div class="min-h-screen bg-slate-950 text-white pb-20">
    <!-- Navbar (Simple) -->
    <nav class="sticky top-0 z-40 bg-slate-950/80 backdrop-blur border-b border-white/5 py-4 px-6 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-violet-500 to-blue-500 flex items-center justify-center text-sm font-black">F</div>
        <span class="font-bold tracking-tight">Fullstack<span class="text-violet-400">Dev</span></span>
      </a>
      <div class="text-sm text-slate-400">Roadmap Pembelajaran</div>
    </nav>

    <!-- Header -->
    <div class="relative px-6 py-16 text-center overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-violet-900/20 to-transparent" />
      <div class="relative z-10 max-w-2xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-black mb-4">Roadmap <span class="bg-gradient-to-r from-violet-400 to-pink-400 bg-clip-text text-transparent">Materi</span></h1>
        <p class="text-slate-400">Pilih modul di bawah ini untuk mulai belajar. Ikuti secara berurutan untuk hasil yang maksimal.</p>
      </div>
    </div>

    <!-- Modul Grid -->
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {sortedModules.map((mod, modIndex) => (
          <div class="bg-white/5 border border-white/10 rounded-3xl overflow-hidden flex flex-col hover:border-white/20 transition-colors">
            
            <!-- Modul Header -->
            <div class={`p-6 border-b border-white/5 bg-gradient-to-br ${mod.bgAccent || 'from-white/5 to-transparent'}`}>
              <div class="flex items-center gap-4 mb-4">
                <div class={`flex-shrink-0 w-14 h-14 rounded-2xl bg-gradient-to-br ${mod.color} flex items-center justify-center text-2xl shadow-lg`}>
                  {mod.emoji}
                </div>
                <div>
                  <div class={`text-xs font-bold tracking-widest uppercase ${mod.accentColor} mb-1`}>Modul 0{modIndex + 1}</div>
                  <h2 class="text-xl font-bold leading-tight">{mod.title}</h2>
                </div>
              </div>
            </div>

            <!-- Modul Content (Lessons) -->
            <div class="flex-1 divide-y divide-white/5">
              {mod.lessons.map((lesson) => (
                <a 
                  href={`/tutorial/${lesson.id}`} 
                  class="block p-4 hover:bg-white/5 transition-colors group/lesson flex items-center gap-4"
                >
                  <div class="text-2xl opacity-80 group-hover/lesson:opacity-100 group-hover/lesson:scale-110 transition-all">{lesson.data.icon}</div>
                  <div class="flex-1 min-w-0">
                    <h3 class="font-semibold text-slate-200 group-hover/lesson:text-white mb-0.5 truncate transition-colors">{lesson.data.title}</h3>
                    <p class="text-xs text-slate-400 line-clamp-1">{lesson.data.description}</p>
                  </div>
                  <div class={`opacity-0 -translate-x-2 group-hover/lesson:opacity-100 group-hover/lesson:translate-x-0 transition-all ${mod.accentColor}`}>
                    →
                  </div>
                </a>
              ))}
            </div>

          </div>
        ))}
      </div>
    </div>

    <!-- Footer -->
    <div class="mt-24 text-center text-slate-500 text-sm">
      <p>Selamat Belajar! 🚀</p>
    </div>
  </div>
</Layout>
