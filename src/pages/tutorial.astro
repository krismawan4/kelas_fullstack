---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allLessons = await getCollection('tutorial');

// Mengelompokkan materi berdasarkan modul
const modules = allLessons.reduce((acc, lesson) => {
  const modId = lesson.data.module;
  if (!acc[modId]) {
    acc[modId] = {
      id: modId,
      title: lesson.data.moduleTitle,
      emoji: lesson.data.moduleEmoji,
      color: lesson.data.moduleColor,
      borderColor: lesson.data.moduleBorderColor,
      accentColor: lesson.data.moduleAccentColor,
      lessons: []
    };
  }
  acc[modId].lessons.push(lesson);
  return acc;
}, {} as Record<string, any>);

// Konversi ke array dan urutkan
const sortedModules = Object.values(modules).sort((a, b) => a.id.localeCompare(b.id));

// Urutkan pelajaran di setiap modul
sortedModules.forEach(mod => {
  mod.lessons.sort((a, b) => a.data.order - b.data.order);
});

const frontmatter = {
  title: 'Roadmap Fullstack Web Developer',
  description: 'Daftar modul dan pelajaran untuk kelas Fullstack.',
};
---

<Layout frontmatter={frontmatter}>
  <div class="min-h-screen bg-slate-950 text-white pb-20">
    <!-- Navbar (Simple) -->
    <nav class="sticky top-0 z-40 bg-slate-950/80 backdrop-blur border-b border-white/5 py-4 px-6 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-violet-500 to-blue-500 flex items-center justify-center text-sm font-black">F</div>
        <span class="font-bold tracking-tight">Fullstack<span class="text-violet-400">Dev</span></span>
      </a>
      <div class="text-sm text-slate-400">Roadmap Pembelajaran</div>
    </nav>

    <!-- Header -->
    <div class="relative px-6 py-16 text-center overflow-hidden">
      <div class="absolute inset-0 bg-gradient-to-b from-violet-900/20 to-transparent" />
      <div class="relative z-10 max-w-2xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-black mb-4">Roadmap <span class="bg-gradient-to-r from-violet-400 to-pink-400 bg-clip-text text-transparent">Materi</span></h1>
        <p class="text-slate-400">Pilih modul di bawah ini untuk mulai belajar. Ikuti secara berurutan untuk hasil yang maksimal.</p>
      </div>
    </div>

    <!-- Modul List -->
    <div class="max-w-4xl mx-auto px-6">
      <div class="space-y-12">
        {sortedModules.map((mod, modIndex) => (
          <div class="relative">
            <!-- Connecting Line -->
            {modIndex !== sortedModules.length - 1 && (
              <div class="absolute left-8 top-20 bottom-[-3rem] w-0.5 bg-white/5 md:left-1/2 md:-ml-px z-0" />
            )}

            <div class="relative z-10 md:flex items-start gap-8 group">
              <!-- Modul Header (Left on Desktop) -->
              <div class="md:w-1/3 mb-6 md:mb-0 md:text-right md:pt-4">
                <div class="flex items-center gap-4 md:justify-end mb-2">
                  <div class={`md:hidden flex-shrink-0 w-16 h-16 rounded-2xl bg-gradient-to-br ${mod.color} flex items-center justify-center text-3xl shadow-xl`}>
                    {mod.emoji}
                  </div>
                  <div>
                    <div class={`text-sm font-bold tracking-widest uppercase ${mod.accentColor}`}>Modul 0{modIndex + 1}</div>
                    <h2 class="text-2xl font-bold">{mod.title}</h2>
                  </div>
                </div>
              </div>

              <!-- Center Icon (Desktop) -->
              <div class="hidden md:flex flex-shrink-0 w-16 h-16 rounded-2xl bg-gradient-to-br transition-transform duration-300 group-hover:scale-110 shadow-xl items-center justify-center text-3xl z-10" class:list={[mod.color]}>
                {mod.emoji}
              </div>

              <!-- Modul Content (Right on Desktop) -->
              <div class="md:w-1/2 flex-1">
                <div class={`bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-white/20 transition-colors`}>
                  <div class="divide-y divide-white/5">
                    {mod.lessons.map((lesson) => (
                      <a 
                        href={`/tutorial/${lesson.id}`} 
                        class="block p-4 hover:bg-white/5 transition-colors group/lesson"
                      >
                        <div class="flex items-start gap-4">
                          <div class="text-2xl mt-0.5 opacity-80 group-hover/lesson:opacity-100 transition-opacity">{lesson.data.icon}</div>
                          <div class="flex-1">
                            <h3 class="font-semibold text-slate-200 group-hover/lesson:text-white mb-1 transition-colors">{lesson.data.title}</h3>
                            <p class="text-xs text-slate-400 line-clamp-1">{lesson.data.description}</p>
                          </div>
                          <div class={`opacity-0 group-hover/lesson:opacity-100 transition-opacity ${mod.accentColor}`}>
                            →
                          </div>
                        </div>
                      </a>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Footer -->
    <div class="mt-24 text-center text-slate-500 text-sm">
      <p>Selamat Belajar! 🚀</p>
    </div>
  </div>
</Layout>
